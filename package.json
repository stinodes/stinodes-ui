{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "lerna exec --ignore storybook --parallel -- tsc -p tsconfig.json",
    "bootstrap": "lerna bootstrap --use-workspaces",
    "bootstrap-all": "lerna bootstrap --use-workspaces && lerna exec --parallel -- lerna bootstrap --use-workspaces",
    "create-package": "bash ./create-package.sh",
    "storybook": "lerna exec --scope storybook -- yarn storybook"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.10",
    "@babel/core": "^7.12.10",
    "@babel/preset-env": "^7.12.11",
    "@babel/preset-react": "^7.12.10",
    "@babel/preset-typescript": "^7.12.7",
    "@emotion/react": "^11.1.4",
    "@emotion/styled": "^11.0.0",
    "@styled-system/should-forward-prop": "^5.1.5",
    "@styled-system/theme-get": "^5.1.2",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/styled-system": "^5.1.10",
    "@types/styled-system__should-forward-prop": "^5.1.2",
    "@types/styled-system__theme-get": "^5.0.1",
    "babel-core": "7.0.0-bridge.0",
    "babel-loader": "^8.2.2",
    "babel-plugin-styled-components": "^1.12.0",
    "emotion": "^11.0.0",
    "emotion-theming": "^11.0.0",
    "lerna": "^3.4.1",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "styled-system": "^5.1.5",
    "typescript": "^4.1.3",
    "webpack": "^5.15.0"
  },
  "dependencies": {
    "@types/ramda": "^0.27.34",
    "polished": "^4.0.5",
    "ramda": "^0.27.1"
  }
}
