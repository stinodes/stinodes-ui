{
  "compilerOptions": {
    "jsxImportSource": "@emotion/react",
    "jsx": "react-jsx",
    "module": "commonjs",
    "declaration": true,
    "noImplicitAny": false,
    "removeComments": true,
    "outDir": "lib",
    "noLib": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es6",
    "sourceMap": true,
    "esModuleInterop": true,
    "lib": [
      "es6",
      "es7",
      "dom"
    ]
  },
  "exclude": [
    ".yarn",
    "node_modules",
    "src/stories/*",
    "lib/*", 
    "**/*.spec.ts",
    "**/*.story.tsx"

  ]
}
